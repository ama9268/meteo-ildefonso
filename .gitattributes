# Normalizar todos los archivos de texto a LF (deploy en Linux/Raspberry Pi)
* text=auto eol=lf

# Python
*.py    text eol=lf
*.cfg   text eol=lf
*.ini   text eol=lf

# Web
*.html  text eol=lf
*.css   text eol=lf
*.js    text eol=lf
*.json  text eol=lf

# Config / deploy
*.conf    text eol=lf
*.service text eol=lf
*.sh      text eol=lf
*.env     text eol=lf
*.md      text eol=lf
*.txt     text eol=lf
*.example text eol=lf

# Binarios — sin conversión
*.png   binary
*.jpg   binary
*.jpeg  binary
*.webp  binary
*.ico   binary
*.xcf   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
