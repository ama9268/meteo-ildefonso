# Copia este archivo a .env y completa los valores
# Genera SECRET_KEY con: python -c "import secrets; print(secrets.token_hex(50))"
SECRET_KEY=cambia-esto-por-una-clave-segura-generada-con-secrets

# True en desarrollo, False en producción
DEBUG=False

# Hosts permitidos, separados por comas
ALLOWED_HOSTS=192.168.1.x,tudominio.com

# PostgreSQL: postgres://usuario:contraseña@host:puerto/nombre_db
# SQLite (solo dev): sqlite:///db.sqlite3
DATABASE_URL=postgres://estacio:contraseña@localhost:5432/estacio_meteo

# Credenciales de la estación Bresser (configurar en "Other Server" de la estación)
# Genera STATION_KEY con: python -c "import secrets; print(secrets.token_hex(32))"
STATION_ID=nombre_estacion
STATION_KEY=genera-con-secrets-token-hex-32

# Email (dejar vacío para usar consola en desarrollo)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=tu@email.com
EMAIL_HOST_PASSWORD=tu-app-password-de-gmail
DEFAULT_FROM_EMAIL=estacion@tudominio.com
